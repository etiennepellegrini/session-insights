{
  "description": "Session insights hooks: auto-reflection on Stop, curation nudge on SessionStart",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/reflect-on-stop.bash",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-insights-size.bash",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
